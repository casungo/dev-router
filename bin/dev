#!/usr/bin/env bash
set -u
set -o pipefail

DEV_ROUTER_VERSION="0.1.1"
DEV_ROUTER_GITHUB_REPO="${DEV_ROUTER_GITHUB_REPO:-casungo/dev-router}"
DEV_ROUTER_AUTO_UPDATE="${DEV_ROUTER_AUTO_UPDATE:-1}"

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/dev-quota"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/dev-router"
ORDER_FILE="${DEV_ROUTER_ORDER_FILE:-$CONFIG_DIR/order}"
CACHE_TTL_SECONDS=300
CHECK_TIMEOUT_SECONDS=3
AUTO_UPDATE_TTL_SECONDS="${DEV_ROUTER_AUTO_UPDATE_TTL_SECONDS:-86400}"
UPDATE_CACHE_FILE="$CACHE_DIR/dev-router-update-check"
DEFAULT_PROVIDER_ORDER=(codex glm antigravity deepseek)

DEV_CODEX_MODEL="${DEV_CODEX_MODEL:-gpt-5.5}"
DEV_GLM_MODEL="${DEV_GLM_MODEL:-GLM-4.7}"
DEV_GLM_FAST_MODEL="${DEV_GLM_FAST_MODEL:-GLM-4.5-Air}"
DEV_AGY_MODEL="${DEV_AGY_MODEL:-Claude Sonnet 4.6 (Thinking)}"
DEV_DEEPSEEK_MODEL="${DEV_DEEPSEEK_MODEL:-deepseek-v4-pro[1m]}"
DEV_DEEPSEEK_FAST_MODEL="${DEV_DEEPSEEK_FAST_MODEL:-deepseek-v4-flash}"

DEV_ROUTER_FILES=(
  bin/dev
  lib/dev-router/core.bash
  lib/dev-router/update.bash
  lib/dev-router/cache-order.bash
  lib/dev-router/providers.bash
  lib/dev-router/commands.bash
)

dev_router_source_dir() {
  local source
  source="${BASH_SOURCE[0]:-$0}"
  if [[ "$source" == */* ]]; then
    (cd "$(dirname "$source")" 2>/dev/null && printf '%s\n' "$PWD")
  else
    dirname "$(command -v "$source")"
  fi
}

DEV_ROUTER_BIN_DIR="$(dev_router_source_dir)"
DEV_ROUTER_ROOT="$(cd "$DEV_ROUTER_BIN_DIR/.." 2>/dev/null && pwd)"
DEV_ROUTER_LIB_DIR="${DEV_ROUTER_LIB_DIR:-$DEV_ROUTER_ROOT/lib/dev-router}"

for dev_router_module in \
  core.bash \
  update.bash \
  cache-order.bash \
  providers.bash \
  commands.bash
do
  if [[ ! -f "$DEV_ROUTER_LIB_DIR/$dev_router_module" ]]; then
    echo "[dev] missing dev-router module: $DEV_ROUTER_LIB_DIR/$dev_router_module" >&2
    echo "[dev] reinstall dev-router or set DEV_ROUTER_LIB_DIR" >&2
    exit 1
  fi
  # shellcheck source=/dev/null
  source "$DEV_ROUTER_LIB_DIR/$dev_router_module"
done
unset dev_router_module

case "${1:-}" in
  -h|--help)
    usage
    ;;
  --version|-v)
    echo "dev-router $DEV_ROUTER_VERSION"
    ;;
  --update)
    update_dev_router
    ;;
  --status|dev-status)
    auto_update_if_due
    status_all
    ;;
  --order)
    shift
    order_command "${1:-show}" "${@:2}"
    ;;
  --use)
    shift
    auto_update_if_due
    direct_launch no "${1:-}" "${@:2}"
    ;;
  --force-use)
    shift
    auto_update_if_due
    direct_launch yes "${1:-}" "${@:2}"
    ;;
  --exhausted-test|--exausted-test)
    shift
    mark_exhausted_for_test "${1:-}"
    ;;
  --clear-cache)
    if [[ -n "${2:-}" ]]; then
      if provider="$(normalize_provider "$2")"; then
        invalidate_cache "$provider"
        echo "[dev] cache cleared for $provider"
      else
        echo "[dev] unknown provider for cache clear: $2" >&2
        exit 2
      fi
    else
      clear_all_cache
    fi
    ;;
  codex|glm|zai|z.ai|z-ai|agy|antigravity|google|deepseek|ds)
    auto_update_if_due
    direct_launch yes "$1" "${@:2}"
    ;;
  *)
    choose_and_launch "$@"
    ;;
esac
