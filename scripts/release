#!/usr/bin/env bash
set -euo pipefail

REPO="${DEV_ROUTER_GITHUB_REPO:-casungo/dev-router}"

usage() {
  cat <<'USAGE'
Usage:
  pnpm release patch|minor|major
  pnpm release <version>

Examples:
  pnpm release patch
  pnpm release 0.1.3
USAGE
}

die() {
  echo "[dev] $*" >&2
  exit 1
}

need_command() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

current_version() {
  local line
  line="$(grep -m 1 '^DEV_ROUTER_VERSION=' bin/dev || true)"
  [[ -n "$line" ]] || die "could not find DEV_ROUTER_VERSION in bin/dev"
  line="${line#DEV_ROUTER_VERSION=}"
  line="${line%\"}"
  line="${line#\"}"
  printf '%s\n' "$line"
}

validate_version() {
  [[ "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || die "version must look like 0.1.2"
}

next_version() {
  local current bump major minor patch
  current="$1"
  bump="$2"
  IFS=. read -r major minor patch <<<"$current"

  case "$bump" in
    patch)
      patch=$((patch + 1))
      ;;
    minor)
      minor=$((minor + 1))
      patch=0
      ;;
    major)
      major=$((major + 1))
      minor=0
      patch=0
      ;;
    *)
      validate_version "$bump"
      printf '%s\n' "$bump"
      return
      ;;
  esac

  printf '%s.%s.%s\n' "$major" "$minor" "$patch"
}

replace_version() {
  local version tmp replaced line
  version="$1"
  tmp="$(mktemp)"
  replaced=0

  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == DEV_ROUTER_VERSION=* && "$replaced" -eq 0 ]]; then
      printf 'DEV_ROUTER_VERSION="%s"\n' "$version" >>"$tmp"
      replaced=1
    else
      printf '%s\n' "$line" >>"$tmp"
    fi
  done <bin/dev

  [[ "$replaced" -eq 1 ]] || {
    rm -f "$tmp"
    die "could not replace DEV_ROUTER_VERSION in bin/dev"
  }

  cat "$tmp" >bin/dev
  rm -f "$tmp"
}

release_notes() {
  local previous_tag range notes
  previous_tag="$1"

  if [[ -n "$previous_tag" ]]; then
    range="${previous_tag}..HEAD"
  else
    range="HEAD"
  fi

  notes="$(git log --format='- %s' "$range")"
  if [[ -z "$notes" ]]; then
    notes="- Release $2."
  fi

  cat <<NOTES
## What's Changed
$notes

## Verification
- bash -n bin/dev install.sh lib/dev-router/*.bash
- ./bin/dev --version
- ./bin/dev --help
NOTES
}

main() {
  local requested current version tag branch previous_tag notes_file

  requested="${1:-}"
  if [[ -z "$requested" || "$requested" == "-h" || "$requested" == "--help" ]]; then
    usage
    exit 0
  fi

  need_command git
  need_command gh
  need_command bash

  [[ -z "$(git status --porcelain)" ]] || die "worktree is not clean"

  branch="$(git branch --show-current)"
  [[ "$branch" == "main" ]] || die "run releases from main, not ${branch:-detached HEAD}"

  current="$(current_version)"
  validate_version "$current"
  version="$(next_version "$current" "$requested")"
  tag="v$version"
  previous_tag="$(git describe --tags --abbrev=0 2>/dev/null || true)"

  [[ "$version" != "$current" ]] || die "new version matches current version: $current"
  ! git rev-parse -q --verify "refs/tags/$tag" >/dev/null || die "tag already exists locally: $tag"
  ! git ls-remote --exit-code --tags origin "$tag" >/dev/null 2>&1 || die "tag already exists on origin: $tag"

  echo "[dev] releasing $current -> $version"
  replace_version "$version"

  bash -n bin/dev install.sh lib/dev-router/*.bash
  ./bin/dev --version | grep -qx "dev-router $version"
  ./bin/dev --help >/dev/null

  notes_file="$(mktemp)"
  release_notes "$previous_tag" "$version" >"$notes_file"

  git add bin/dev
  git commit -m "Bump dev-router to $version"
  git push origin main
  git tag -a "$tag" -m "dev-router $version"
  git push origin "$tag"
  gh release create "$tag" --repo "$REPO" --title "dev-router $version" --notes-file "$notes_file"
  rm -f "$notes_file"

  echo "[dev] published https://github.com/${REPO}/releases/tag/${tag}"
}

main "$@"
